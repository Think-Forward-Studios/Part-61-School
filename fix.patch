+// Mirrors apps/web/app/(app)/schedule/Calendar.tsx#parseRangeLiteral.
+// Accepts both `[2026-05-01 14:00:00+00,2026-05-01 15:00:00+00)` and the
+// quoted-bound variant Postgres emits for tstzrange. Returns null if the
+// literal can't be parsed so callers can fall back gracefully.
+function parseRangeLiteral(range: string): { start: Date; end: Date } | null {
+  const m = range.match(/^[\[(]\s*"?([^",]+)"?\s*,\s*"?([^"\)]+)"?\s*[\])]$/);
+  if (!m) return null;
+  const norm = (s: string) =>
+    s.trim().replace(' ', 'T').replace(/([+-]\d{2})$/, '$1:00');
+  const start = new Date(norm(m[1]!));
+  const end = new Date(norm(m[2]!));
+  if (isNaN(start.getTime()) || isNaN(end.getTime())) return null;
+  return { start, end };
+}
+
+function formatWhen(range: string, tz: string): string {
+  const parsed = parseRangeLiteral(range);
+  if (!parsed) return range;
+  const dateFmt = new Intl.DateTimeFormat('en-US', {
+    weekday: 'short',
+    month: 'short',
+    day: 'numeric',
+    year: 'numeric',
+    timeZone: tz,
+  });
+  const timeFmt = new Intl.DateTimeFormat('en-US', {
+    hour: 'numeric',
+    minute: '2-digit',
+    timeZone: tz,
+    timeZoneName: 'short',
+  });
+  return `${dateFmt.format(parsed.start)}  ${timeFmt.format(parsed.start)} – ${timeFmt.format(parsed.end)}`;
+}
