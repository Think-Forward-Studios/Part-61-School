# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database connections.
#
# DATABASE_URL MUST be the Supabase transaction-mode pooler (port :6543).
#   This is what the Next.js runtime uses for normal queries. Session/statement
#   pooling on :5432 will NOT work because Drizzle relies on prepared statements
#   that conflict with the pgbouncer session mode. See research Pitfall 10.
#
# DIRECT_DATABASE_URL MUST be the direct (non-pooled) database connection.
#   Drizzle Kit migrations require a direct connection because they run DDL,
#   advisory locks, and multi-statement migrations the pooler cannot proxy.
DATABASE_URL=
DIRECT_DATABASE_URL=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# External integrations
ADSB_API_BASE_URL=http://localhost:3002
NEXT_PUBLIC_ADSB_API_URL=http://localhost:3002/api

# ----------------------------------------------------------------------------
# Phase 8 — Resend transactional email (https://resend.com)
# ----------------------------------------------------------------------------
#
# RESEND_API_KEY     Create at https://resend.com/api-keys — free tier gives
#                    3,000 emails/month, 100/day, 2 req/s. Starts with `re_`.
#
# RESEND_FROM_EMAIL  Must match a verified sender domain in the Resend
#                    dashboard (Domains -> Add Domain -> copy DKIM + SPF
#                    DNS records to your registrar). For local dev,
#                    `onboarding@resend.dev` works without verification.
#
# INTERNAL_WORKER_SECRET
#                    Any strong random string. Generate with:
#                      openssl rand -hex 32
#                    The SAME value must be set on the Postgres side so the
#                    pg_cron drain job can authenticate into /api/emails/send:
#                      alter database postgres set app.internal_worker_secret = '<secret>';
#                      alter database postgres set app.email_worker_url       = 'https://your-host/api/emails/send';
#                    (Replace "postgres" with your Supabase DB name in prod.)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
INTERNAL_WORKER_SECRET=
